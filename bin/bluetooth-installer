#!/bin/bash
echo ""
read -p "   [0;33mBluetooth Installer[0m

   This script will install the packages necessary for bluetooth use.
   
   Once installed, you can choose to open open the Bluetooth Manager
   directly from the Settings menu. The Blueman Applet will appear
   in the system tray after logging out and back in.
   
   [0;32m------------------------------------------------------------------
   
   Please press enter to install the bluetooth packages.
   
   ------------------------------------------------------------------[0m
      
   Or close this terminal window to quit the install." ;
   if : >/dev/tcp/8.8.8.8/53; then
echo ""
sudo apt update && sudo apt install --install-recommends -y bluetooth \
bluez-tools bluez-obexd blueman libspa-0.2-bluetooth gstreamer1.0-gl \
gstreamer1.0-x gstreamer1.0-plugins-bad rfkill

echo ""
echo " [0;33m--------------------------------------------------------------------[0m"
echo ""
echo " [0;33mAll Finished! Find 'Bluetooth Manager' in the menu under 'Settings'[0m"
echo " [0;33mThe Blueman applet will appear in the system tray after next login.[0m"
echo ""
echo " [0;33m--------------------------------------------------------------------[0m"
echo ""
else
echo ""
echo " [0;31m-----------------------------------------------------[0m"
echo ""
echo " [0;33mNo Internet connection. Please connect and try again.[0m"
echo ""
echo " [0;31m-----------------------------------------------------[0m"
echo ""
fi
read -n1 -p " Press any key to quit this dialog ... "
