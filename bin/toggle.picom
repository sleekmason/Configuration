#!/bin/bash

FILE="$HOME/.config/autostart/picom.desktop"
if pgrep -x picom > /dev/null; then
    pkill -x picom
    conkyrestart >/dev/null 2>&1 &
    sed -i 's/Hidden=.*/Hidden=true/' "$FILE"
    notify-send "Picom deactivated - autostart disabled"
else
    picom --daemon
    conkyrestart >/dev/null 2>&1 &
    sed -i 's/Hidden=.*/Hidden=false/' "$FILE"
    notify-send "Picom activated - autostart enabled"
fi
