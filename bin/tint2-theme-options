#!/bin/bash
# Toggle tint2 position.
# Made by sleekmason 2 Aug-2023

bottomside(){
  FILE="$HOME/.config/tint2/tint2rc"
  sed -i \
  -e 's/task_text =.*/task_text = 1/' \
  -e 's/panel_position =.*/panel_position = bottom center horizontal/' \
  -e 's/^panel_size =.*/panel_size = 100% 22/g' \
  -e 's/^button_max_icon_size =.*/button_max_icon_size = 15 100/g' \
  -e 's/^systray_icon_size =.*/systray_icon_size = 15 100/g' \
  -e 's/^launcher_icon_size =.*/launcher_icon_size = 16 100/g' \
  -e 's/^execp_icon_w =.*/execp_icon_w = 17/g' \
  -e 's/^execp_icon_h =.*/execp_icon_h = 17/g' \
  -e 's/^button_font = .*/button_font = Noto Sans 11/g' \
  -e 's/^execp_font = .*/execp_font = Noto Sans 11/g' \
  -e 's/^bat1_font = .*/bat1_font = Noto Sans 11/g' \
  -e 's/^time1_font = .*/time1_font = Noto Sans 11/g' \
  -e 's/^task_font = .*/task_font = Noto Sans Display 10.5/g' \
  -e 's/^taskbar_name_font = .*/taskbar_name_font = Noto Sans 10/g' \
  -e 's/^task_maximum_size =.*/task_maximum_size = 150 20/g' \
  -e 's/^task_align =.*/task_align = left/g' "$FILE"
  killall -SIGUSR1 tint2
  killall pnmixer 2>/dev/null
  pnmixer >/dev/null 2>&1 &
}

topside(){
  FILE="$HOME/.config/tint2/tint2rc"
  sed -i \
  -e 's/task_text =.*/task_text = 1/' \
  -e 's/panel_position =.*/panel_position = top center horizontal/' \
  -e 's/^panel_size =.*/panel_size = 100% 22/g' \
  -e 's/^button_max_icon_size =.*/button_max_icon_size = 15 100/g' \
  -e 's/^systray_icon_size =.*/systray_icon_size = 15 100/g' \
  -e 's/^launcher_icon_size =.*/launcher_icon_size = 16 100/g' \
  -e 's/^execp_icon_w =.*/execp_icon_w = 17/g' \
  -e 's/^execp_icon_h =.*/execp_icon_h = 17/g' \
  -e 's/^button_font = .*/button_font = Noto Sans 11/g' \
  -e 's/^execp_font = .*/execp_font = Noto Sans 11/g' \
  -e 's/^bat1_font = .*/bat1_font = Noto Sans 11/g' \
  -e 's/^time1_font = .*/time1_font = Noto Sans 11/g' \
  -e 's/^task_font = .*/task_font = Noto Sans Display 10.5/g' \
  -e 's/^taskbar_name_font = .*/taskbar_name_font = Noto Sans 10/g' \
  -e 's/^task_maximum_size =.*/task_maximum_size = 150 20/g' \
  -e 's/^task_align =.*/task_align = left/g' "$FILE"
  killall -SIGUSR1 tint2
  killall pnmixer 2>/dev/null
  pnmixer >/dev/null 2>&1 &
}

leftside(){
  FILE="$HOME/.config/tint2/tint2rc"
  sed -i \
  -e 's/task_text =.*/task_text = 0/' \
  -e 's/panel_position =.*/panel_position = center left vertical/' \
  -e 's/^panel_size =.*/panel_size = 100% 44/g' \
  -e 's/^button_max_icon_size =.*/button_max_icon_size = 16 100/g' \
  -e 's/^systray_icon_size =.*/systray_icon_size = 22 100/g' \
  -e 's/^launcher_icon_size =.*/launcher_icon_size = 18 100/g' \
  -e 's/^execp_icon_w =.*/execp_icon_w = 17/g' \
  -e 's/^execp_icon_h =.*/execp_icon_h = 17/g' \
  -e 's/^button_font = .*/button_font = Noto Sans 11/g' \
  -e 's/^execp_font = .*/execp_font = Noto Sans 11/g' \
  -e 's/^bat1_font = .*/bat1_font = Noto Sans Bold 9/g' \
  -e 's/^time1_font = .*/time1_font = Noto Sans Bold 9/g' \
  -e 's/^task_font = .*/task_font = Noto Sans Display 9/g' \
  -e 's/^taskbar_name_font = .*/taskbar_name_font = Noto Sans 10/g' \
  -e 's/^task_maximum_size =.*/task_maximum_size = 150 22/g' \
  -e 's/^task_align =.*/task_align = center/g' "$FILE"
  killall -SIGUSR1 tint2
  killall pnmixer 2>/dev/null
  pnmixer >/dev/null 2>&1 &
}

rightside(){
  FILE="$HOME/.config/tint2/tint2rc"
  sed -i \
  -e 's/task_text =.*/task_text = 0/' \
  -e 's/panel_position =.*/panel_position = center right vertical/' \
  -e 's/^panel_size =.*/panel_size = 100% 44/g' \
  -e 's/^button_max_icon_size =.*/button_max_icon_size = 16 100/g' \
  -e 's/^systray_icon_size =.*/systray_icon_size = 22 100/g' \
  -e 's/^launcher_icon_size =.*/launcher_icon_size = 18 100/g' \
  -e 's/^execp_icon_w =.*/execp_icon_w = 17/g' \
  -e 's/^execp_icon_h =.*/execp_icon_h = 17/g' \
  -e 's/^button_font = .*/button_font = Noto Sans 11/g' \
  -e 's/^execp_font = .*/execp_font = Noto Sans 11/g' \
  -e 's/^bat1_font = .*/bat1_font = Noto Sans Bold 9/g' \
  -e 's/^time1_font = .*/time1_font = Noto Sans Bold 9/g' \
  -e 's/^task_font = .*/task_font = Noto Sans Display 9/g' \
  -e 's/^taskbar_name_font = .*/taskbar_name_font = Noto Sans 10/g' \
  -e 's/^task_maximum_size =.*/task_maximum_size = 150 22/g' \
  -e 's/^task_align =.*/task_align = center/g' "$FILE"
  killall -SIGUSR1 tint2
  killall pnmixer 2>/dev/null
  pnmixer >/dev/null 2>&1 &
}

export -f bottomside
export -f topside
export -f leftside
export -f rightside

yad --title "Tint2 Theme Options" --escape-ok --borders=14 \
--form --geometry=240x220-268-84 \
--text="Bar size resets to default on position change\n" --text-align=center --buttons-layout=edge \
--button=" Tint2 Size!applications-other:tint2-iconsize" \
--button=" Icon Theme!org.xfce.settings.color:tint2-iconcolor" \
--button="gtk-ok:0" \
--window-icon=dialog-information \
    --form --columns=2 \
    --field=" Top":FBTN "bash -c topside >/dev/null 2>&1 &" \
    --field=" Bottom":FBTN "bash -c bottomside >/dev/null 2>&1 &" \
    --field=" Left":FBTN "bash -c leftside >/dev/null 2>&1 &" \
    --field=" Right":FBTN "bash -c rightside >/dev/null 2>&1 &"
