#!/bin/bash
# Adjust tint2 icons
# Author - sleekmason 06/14/2023

ozark(){
  FILE="$HOME/.config/tint2/tint2rc"
  sed -i \
  -e 's/\~\/.config\/tint2\/tint2-custom\//\/usr\/share\/icons\/ld-icons\/coltint2light\//g' \
  -e 's/coltint2.*\//coltint2ozark\//g' \
  -e 's/\(coltint2ozark.*\)....*$/\1svg/g' \
  -e 's/taskbar_name_font_color =.*/taskbar_name_font_color = \#CCDFE8 100/' \
  -e 's/taskbar_name_active_font_color =.*/taskbar_name_active_font_color = \#CCDFE8 100/' \
  -e 's/task_font_color =.*/task_font_color = \#CCDFE8 100/' \
  -e 's/clock_font_color =.*/clock_font_color = \#CCDFE8 100/' \
  -e 's/tooltip_font_color =.*/tooltip_font_color = \#CCDFE8 100/' \
  -e 's/^battery_font_color.*/battery_font_color = #CCDFE8 100/g' "$FILE"
  killall -SIGUSR1 tint2
  killall pnmixer 2>/dev/null
  pnmixer >/dev/null 2>&1 &
}

