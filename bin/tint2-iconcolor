}

custom_color(){
  if test -e "$HOME/.config/tint2/customcolor.txt"; then
    FILE="$HOME/.config/tint2/tint2rc"
    sed -i \
    -e 's/coltint2.*\//coltint2light\//g' \
    -e 's/\(coltint2light.*\)....*$/\1svg/g' \
    -e 's/\/usr\/share\/icons\/ld-icons\/coltint2light\//\~\/.config\/tint2\/tint2-custom\//g' "$FILE"
    COLOR_CHOICE=$(cat "$HOME/.config/tint2/customcolor.txt")
    sed -i \
    -e 's/taskbar_name_font_color =.*/taskbar_name_font_color = \'"$COLOR_CHOICE"' 100/' \
    -e 's/taskbar_name_active_font_color =.*/taskbar_name_active_font_color = \'"$COLOR_CHOICE"' 100/' \
    -e 's/task_font_color =.*/task_font_color = \'"$COLOR_CHOICE"' 100/' \
    -e 's/clock_font_color =.*/clock_font_color = \'"$COLOR_CHOICE"' 100/' \
    -e 's/tooltip_font_color =.*/tooltip_font_color = \'"$COLOR_CHOICE"' 100/' \
    -e 's/^battery_font_color.*/battery_font_color = '"$COLOR_CHOICE"' 100/g' "$FILE"
    killall -SIGUSR1 tint2
    killall pnmixer 2>/dev/null
    pnmixer >/dev/null 2>&1 &
  else
    exit
  fi
}

export -f ozark
export -f forge
export -f creme
export -f light
export -f grey
export -f adobe
export -f navy
export -f green
export -f teladog
export -f teladog2
export -f telacircle
export -f buuf
export -f obsidian
export -f papirus
export -f black
export -f white
export -f custom_color

yad --title "Icon Themes" --escape-ok --borders=14 \
--form --geometry=240x450-270-352 \
--text="Tint2 Icon Themes\n" --text-align=center --buttons-layout=edge \
--window-icon=org.xfce.settings.color \
--button=" Custom!org.xfce.settings.color:bash -c 'tint2-custom-color'" \
--button="OK!gtk-ok:0" \
    --form --columns=2 \
    --field=" Light":FBTN "bash -c light >/dev/null 2>&1 &" \
    --field=" Ozark":FBTN "bash -c ozark >/dev/null 2>&1 &" \
    --field=" Grey":FBTN "bash -c grey >/dev/null 2>&1 &" \
    --field=" Creme":FBTN "bash -c creme >/dev/null 2>&1 &" \
    --field=" Adobe":FBTN "bash -c adobe >/dev/null 2>&1 &" \
    --field=" Teladog":FBTN "bash -c teladog >/dev/null 2>&1 &" \
    --field=" Teladog2":FBTN "bash -c teladog2 >/dev/null 2>&1 &" \
    --field=" Telacircle":FBTN "bash -c telacircle >/dev/null 2>&1 &" \
    --field=" White":FBTN "bash -c white >/dev/null 2>&1 &" \
    --field=" Forge":FBTN "bash -c forge >/dev/null 2>&1 &" \
    --field=" Navy":FBTN "bash -c navy >/dev/null 2>&1 &" \
    --field=" Green":FBTN "bash -c green >/dev/null 2>&1 &" \
    --field=" Buuf":FBTN "bash -c buuf >/dev/null 2>&1 &" \
    --field=" Obsidian":FBTN "bash -c obsidian >/dev/null 2>&1 &" \
    --field=" Papirus":FBTN "bash -c papirus >/dev/null 2>&1 &" \
    --field=" Custom":FBTN "bash -c custom_color >/dev/null 2>&1 &"
