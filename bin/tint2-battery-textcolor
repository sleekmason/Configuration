#!/bin/bash
# tint2 battery color options
# Made by sleekmason for Lilidog 4-13-2022

FILE="$HOME/.config/tint2/tint2rc"

noti=$(yad --width 310 --borders=12 --entry --title "Percentage Text Color" --center --window-icon=applications-graphics \
    --image="/usr/share/icons/hicolor/24x24/apps/org.xfce.settings.color.png" \
    --button="gtk-cancel:1" --button="gtk-ok:0" \
    "Light" "Ozark" "Forge" "Creme" "White" "Grey" "Black" "Adobe" "Navy" "Green" "Red" "Blue" "Orange" "Teladog" "Teladog2" "Buuf" "Obsidian" "Papirus")

case $noti in
  Ozark)    color="#CCDFE8" ;;
  Forge)    color="#C6D7E6" ;;
  Creme)    color="#E1DFDB" ;;
  Light)    color="#E3E3E3" ;;
  Green)    color="#26E06A" ;;
  Red)      color="#FF3352" ;;
  Blue)     color="#31ECE5" ;;
  Orange)   color="#FFA43E" ;;
  Teladog)  color="#ffffff" ;;
  Teladog2) color="#ffffff" ;;
  Buuf)     color="#CCC8BB" ;;
  White)    color="#ffffff" ;;
  Grey)     color="#A2AAB3" ;;
  Black)    color="#000000" ;;
  Adobe)    color="#C2BEB2" ;;
  Navy)     color="#A0BED9" ;;
  Obsidian) color="#ffffff" ;;
  Papirus)  color="#ffffff" ;;
  *)        exit 1 ;;
esac

sed -i "s/^battery_font_color.*/battery_font_color = $color 100/g" "$FILE"
killall -SIGUSR1 tint2
killall pnmixer 2>/dev/null
pnmixer >/dev/null 2>&1 &
