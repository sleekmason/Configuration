#!/bin/bash
# Display sxhkd + Openbox keybindings
# Created for Lilidog by sleekmason 5 Feb. 2026

SXHKD_CONFIG="$HOME/.config/openbox/sxhkdrc-open"
OB_CONFIG="$HOME/.config/openbox/rc.xml"

clear

HEAD_COLOR="\033[94m"
GREEN="\033[32m"
BLUE="\033[34m"
YELLOW="\033[33m"
RESET="\033[0m"
KEY_WIDTH=30
MAX_LINE=86

# Use the followiing section to change the output names as desired.
declare -A FRIENDLY_NAMES=(

  ["pkill -USR1 -x sxhkd"]="Reload sxhkd"
  ["ld-keys"]="Show Keybinds"

  ["rofi-familiar"]="Rofi Full"
  ["rofi -show drun"]="Rofi Apps"
  ["xdmenu"]="Dmenu"
  ["jgmenu_run"]="jgmenu"

  ["ld-themes"]="Auto Themes"
  ["light-dark-toggle"]="Light/Dark Theme Toggle"
  ["custom-theme-toggle"]="Alt Theme Toggle"
  ["toggle.ld"]="Hotcorners Toggle"

  ["conky-toggle"]="Conky Toggle"
  ["toggle.polybar"]="Polybar Toggle (if installed)"
  ["toggle.tint2"]="Tint2 Toggle"
  ["tint2-options"]="Tint2 Options"

  ["x-terminal-emulator"]="Terminal"
  ["thunar"]="Thunar File Manager"
  ["splitview"]="Split View"
  ["geany"]="Geany Editor"
  ["pragha"]="Pragha Music Player"
  ["x-www-browser"]="Web Browser"

  ["toggle.picom"]="Picom Toggle (transparency)"
  ["toggle.gammy"]="Gammy Toggle"
  ["xfconf-query"]="Thunar Window Split"
  ["feh-set-wallpaper"]="Wallpapers"
  ["wallpaper-keybind-toggle"]="Random BG"
  
  ["ld-logout"]="Logout"
  ["nakedquit"]="Logout Alternate"

  ["pamixer --decrease"]="Volume Down"
  ["pamixer --increase"]="Volume Up"
  ["pamixer --toggle-mute"]="Volume Mute"

  ["brightnessctl s 10%-"]="Brightness Down"
  ["brightnessctl s 10%+"]="Brightness Up"

  ["xfce4-screenshooter"]="Screenshot"
  ["scrot-options"]="Scrot Options"
)

# SXHKD keybinds
echo -e " ${YELLOW}STANDARD KEYBINDS - SXHKD - (Adjust in: ~/.config/openbox/sxhkdrc-open)${RESET}"
echo -e " ${YELLOW}-----------------------------------------------------------------------${RESET}"

{
for key in "${!FRIENDLY_NAMES[@]}"; do
    echo "$key:::${FRIENDLY_NAMES[$key]}"
done
echo "__DATA__"
cat "$SXHKD_CONFIG"
} | awk -v BLUE="$BLUE" \
        -v GREEN="$GREEN" \
        -v RESET="$RESET" \
        -v KEY_WIDTH="$KEY_WIDTH" \
        -v MAX_LINE="$MAX_LINE" \
        -v YELLOW="$YELLOW" '

BEGIN{
    CKEY=YELLOW
    CDET=BLUE
    mode="friendly"
}

mode=="friendly" && $0=="__DATA__" { mode="sxhkd"; next }

mode=="friendly" {
    split($0,p,":::")
    friendly[p[1]]=p[2]
    next
}

mode=="sxhkd" && /^[ \t]*#/ { next }
mode=="sxhkd" && /^[ \t]*$/ { next }

mode=="sxhkd" && !/^[ \t]/ {
    key=$0
    next
}

mode=="sxhkd" {
    cmd=$0
    sub(/^[ \t]+/,"",cmd)
    sub(/[ \t]+$/,"",cmd)

    k=key
    gsub(/mod4/,"Super",k)
    gsub(/shift/,"Shift",k)
    gsub(/ctrl/,"Ctrl",k)
    gsub(/alt/,"Alt",k)
    gsub(/[ ]*\+[ ]*/,"+",k)

    label=cmd

    if (cmd ~ /(x-terminal-emulator|xfce4-terminal|kitty|alacritty|gnome-terminal).* -e /) {
        split(cmd,a," -e ")
        split(a[2],b," ")
        label=b[1]
    }

    bestlen=0
    for (f in friendly) {
        if (index(label, f) && length(f) > bestlen) {
            label = friendly[f]
            bestlen = length(f)
        }
    }

    line=sprintf(" %s%-*s%s  %s%s%s",CKEY,KEY_WIDTH,k,RESET,CDET,label,RESET)

    if(length(line)>MAX_LINE)
        line=substr(line,1,MAX_LINE-3)"..."

    print line
}
' | sort


# Openbox keybinds
echo
echo -e " ${YELLOW}OPENBOX KEYBINDS - W=Super  S=Shift  C=Ctrl (~/.config/openbox/rc.xml)${RESET}"
echo -e " ${YELLOW}----------------------------------------------------------------------${RESET}"

awk -v YELLOW="$YELLOW" -v GREEN="$GREEN" -v BLUE="$BLUE" -v RESET="$RESET" -v KEY_WIDTH="$KEY_WIDTH" -v MAX_LINE="$MAX_LINE" '
BEGIN {
    CKEY=YELLOW
    CACT=BLUE
    CRESET=RESET
}

/<keybind key=/ {
    key=$0
    gsub(/.*key="/,"",key)
    gsub(/".*/,"",key)
    action=""
}

/<action name=/ {
    action=$0
    gsub(/.*name="/,"",action)
    gsub(/".*/,"",action)
}

/<\/keybind>/ {
    desktop_num=""
    if (key ~ /-[0-9]+$/)
        desktop_num=substr(key,match(key,/[0-9]+$/))

    if ((action=="GoToDesktop" || action=="SendToDesktop") && desktop_num!="")
        action=action" "desktop_num

    printf " %s%-*s%s  %s%-15s%s\n",
        CKEY,KEY_WIDTH,key,CRESET,
        CACT,action,CRESET
}
' "$OB_CONFIG" | sort

echo
read -n1 -s -r -p "Press any key to close..."
echo
