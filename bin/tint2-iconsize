		-e 's/^time1_font = .*/time1_font = Noto Sans Bold 8/g' \
		-e 's/^task_font = .*/task_font = Noto Sans Display 9/g' \
		-e 's/^taskbar_name_font = .*/taskbar_name_font = Noto Sans 8/g' \
		-e 's/^task_maximum_size =.*/task_maximum_size = 150 20/g' "$FILE"
	fi
	killall -SIGUSR1 tint2
	killall pnmixer 2>/dev/null
	pnmixer >/dev/null 2>&1 &
}

