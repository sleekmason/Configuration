		-e 's/^launcher_icon_size =.*/launcher_icon_size = 14 100/g' \
		-e 's/^execp_icon_w =.*/execp_icon_w = 14/g' \
		-e 's/^execp_icon_h =.*/execp_icon_h = 14/g' \
		-e 's/^panel_size =.*/panel_size = 100% 38/g' \
