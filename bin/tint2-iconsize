#!/bin/bash
# Adjust tint2 icon size
# Author - sleekmason 06/15/2023
# This dialog is implemented through the tint2-theme-options dialog

size12() {
	FILE="$HOME/.config/tint2/tint2rc"
	if grep -q horizontal "$FILE"; then
		sed -i \
		-e 's/^button_max_icon_size =.*/button_max_icon_size = 11 100/g' \
		-e 's/^systray_icon_size =.*/systray_icon_size = 12 100/g' \
		-e 's/^launcher_icon_size =.*/launcher_icon_size = 13 100/g' \
		-e 's/^execp_icon_w =.*/execp_icon_w = 13/g' \
		-e 's/^execp_icon_h =.*/execp_icon_h = 13/g' \
		-e 's/^panel_size =.*/panel_size = 100% 17/g' \
		-e 's/^button_font = .*/button_font = Noto Sans 9/g' \
		-e 's/^execp_font = .*/execp_font = Noto Sans 9/g' \
		-e 's/^bat1_font = .*/bat1_font = Noto Sans 8/g' \
		-e 's/^time1_font = .*/time1_font = Noto Sans 8/g' \
		-e 's/^task_font = .*/task_font = Noto Sans Display 8/g' \
		-e 's/^taskbar_name_font = .*/taskbar_name_font = Noto Sans 8/g' \
		-e 's/^task_maximum_size =.*/task_maximum_size = 150 15/g' "$FILE"
	else
		sed -i \
		-e 's/^button_max_icon_size =.*/button_max_icon_size = 13 100/g' \
		-e 's/^systray_icon_size =.*/systray_icon_size = 17 100/g' \
		-e 's/^launcher_icon_size =.*/launcher_icon_size = 14 100/g' \
		-e 's/^execp_icon_w =.*/execp_icon_w = 13/g' \
		-e 's/^execp_icon_h =.*/execp_icon_h = 13/g' \
		-e 's/^panel_size =.*/panel_size = 100% 34/g' \
		-e 's/^button_font = .*/button_font = Noto Sans 9/g' \
		-e 's/^execp_font = .*/execp_font = Noto Sans 9/g' \
		-e 's/^bat1_font = .*/bat1_font = Noto Sans Bold 7/g' \
		-e 's/^time1_font = .*/time1_font = Noto Sans Bold 7/g' \
		-e 's/^task_font = .*/task_font = Noto Sans Display 8/g' \
		-e 's/^taskbar_name_font = .*/taskbar_name_font = Noto Sans 8/g' \
		-e 's/^task_maximum_size =.*/task_maximum_size = 150 18/g' "$FILE"
	fi
	killall -SIGUSR1 tint2
	killall pnmixer 2>/dev/null
	pnmixer >/dev/null 2>&1 &
}

