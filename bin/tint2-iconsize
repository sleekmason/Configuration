export -f size12
export -f size14
export -f size16
export -f size18
export -f size20
export -f size22
export -f size24
export -f size26

yad --title "Tint2 Size" --escape-ok --borders=14 \
	--geometry=220x292-532-353 --buttons-layout=edge \
	--text="Default = 18\n" --text-align=center \
	--window-icon=tint2-conf \
	--form --columns=2 \
	--field=" 12":FBTN "bash -c size12 >/dev/null 2>&1 &" \
	--field=" 14":FBTN "bash -c size14 >/dev/null 2>&1 &" \
	--field=" 16":FBTN "bash -c size16 >/dev/null 2>&1 &" \
	--field=" 18":FBTN "bash -c size18 >/dev/null 2>&1 &" \
	--field=" 20":FBTN "bash -c size20 >/dev/null 2>&1 &" \
	--field=" 22":FBTN "bash -c size22 >/dev/null 2>&1 &" \
	--field=" 24":FBTN "bash -c size24 >/dev/null 2>&1 &" \
	--field=" 26":FBTN "bash -c size26 >/dev/null 2>&1 &"
